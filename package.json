{
  "name": "devdocs-ai-copilot",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build:shared": "tsc -p packages/shared/tsconfig.json",
    "prepare": "tsc -p packages/shared/tsconfig.json",
    "dev:backend": "cd apps/backend && bun run start:dev",
    "dev:frontend": "cd apps/frontend && bun run dev",
    "db:up": "docker compose up -d postgres pgadmin redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres pgadmin redis",
    "migration:run": "cd apps/backend && bun run migration:run"
  },
  "devDependencies": { "typescript": "^5.5.4" }
}
